local function NotificarExecucao(autorizado)
    local ThumbType = Enum.ThumbnailType.HeadShot
    local ThumbSize = Enum.ThumbnailSize.Size600x600
    local Content, IsReady = Players:GetUserThumbnailAsync(LPlayer.UserId, ThumbType, ThumbSize)
    
    local ProfileLink = "https://www.roblox.com/users/" .. LPlayer.UserId .. "/profile"
    local ServerLink = "https://www.roblox.com/games/" .. game.PlaceId .. "?jobId=" .. game.JobId
    
    local Cor = autorizado and 0xDEFF9A or 0xFF4545
    local StatusTexto = autorizado and "✅ ACESSO PERMITIDO" or "❌ ACESSO NEGADO"

    local data = {
        ["embeds"] = {{
            ["title"] = "🚀 tw programer - Monitoramento",
            ["color"] = Cor,
            ["thumbnail"] = { ["url"] = Content },
            ["fields"] = {
                {["name"] = "Status:", ["value"] = "**" .. StatusTexto .. "**", ["inline"] = false},
                {["name"] = "👤 Usuário:", ["value"] = "[" .. LPlayer.Name .. "](" .. ProfileLink .. ")", ["inline"] = true},
                {["name"] = "🆔 ID:", ["value"] = tostring(LPlayer.UserId), ["inline"] = true},
                {["name"] = "🎮 Jogo:", ["value"] = MarketplaceService:GetProductInfo(game.PlaceId).Name, ["inline"] = false},
                {["name"] = "🔗 Servidor:", ["value"] = "[Clique para entrar](" .. ServerLink .. ")", ["inline"] = false},
                {["name"] = "🕒 Horário:", ["value"] = os.date("%H:%M:%S | %d/%m/%Y"), ["inline"] = false}
            },
            ["footer"] = {["text"] = "Segurança TW"}
        }}
    }
    
    pcall(function()
        local payload = HttpService:JSONEncode(data)
        local requestFunc = syn and syn.request or http_request or request or (http and http.request)
        if requestFunc then
            requestFunc({
                Url = MeuWebhook,
                Method = "POST",
                Headers = {["Content-Type"] = "application/json"},
                Body = payload
            })
        end
    end)
end

-- VERIFICAÇÃO DE WHITELIST
local function IsWhitelisted()
    local Success, Content = pcall(function()
        return game:HttpGet('https://raw.githubusercontent.com/twprogamer/tw-whitelist/refs/heads/main/whitelist.txt')
    end)
    if Success then
        return string.find(Content, tostring(LPlayer.UserId)) ~= nil
    end
    return false
end

local Whitelisted = IsWhitelisted()
NotificarExecucao(Whitelisted)

if not Whitelisted then
    LPlayer:Kick("\n[tw programer 🚀]\nACESSO NEGADO.\nSeu ID: " .. LPlayer.UserId .. " não está na Whitelist.")
    return 
end

