-- VARIÁVEIS DE CONTROLE
local DelayMin, DelayMax = 1.5, 3.5
local Mode = "Seguro"
local Logs = {}

local function GetDelay()
    if Mode == "Rápido" then return 1.5 end
    return math.random() * (DelayMax - DelayMin) + DelayMin
end

local function AddLog(msg)
    local t = os.date("%H:%M:%S")
    table.insert(Logs, 1, "["..t.."] "..msg)
    if #Logs > 12 then table.remove(Logs, 13) end
end

